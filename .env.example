# ─── DATABASE ────────────────────────────────────────────────────────────────
# Neon Postgres — use the pooled connection string from your Neon dashboard
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/attribution?sslmode=require

# ─── AUTH ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-app.vercel.app

# ─── HUBSPOT — USER AUTH APP ─────────────────────────────────────────────────
# Create an app at https://app.hubspot.com/developer/
# Scopes: openid, email, profile (for agency staff login)
# Redirect URL: https://your-app.vercel.app/api/auth/callback/hubspot
HUBSPOT_CLIENT_ID=your-user-auth-app-client-id
HUBSPOT_CLIENT_SECRET=your-user-auth-app-client-secret

# ─── HUBSPOT — CLIENT PORTAL APP ─────────────────────────────────────────────
# Create a SECOND HubSpot app for connecting client portals
# Scopes: contacts, deals, content, crm.objects.contacts.read, crm.objects.deals.read
# Redirect URL: https://your-app.vercel.app/api/hubspot/callback
HUBSPOT_CLIENT_PORTAL_ID=your-client-portal-app-client-id
HUBSPOT_CLIENT_PORTAL_SECRET=your-client-portal-app-client-secret

# ─── EMAIL ───────────────────────────────────────────────────────────────────
# Resend API key — https://resend.com
EMAIL_API_KEY=re_your-resend-api-key
# Email address to send alerts FROM (must be verified in Resend)
EMAIL_FROM=alerts@yourdomain.com

# ─── SECURITY ────────────────────────────────────────────────────────────────
# For encrypting HubSpot client OAuth tokens in the database
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-64-char-hex-string

# HMAC key for signing OAuth state params (prevent CSRF on client portal connect)
# Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=your-64-char-hex-string

# Protects /api/cron/* endpoints from public access
# Generate with: openssl rand -hex 24
CRON_SECRET=your-cron-secret
